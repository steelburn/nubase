# Copy to /root/nubase/nubase.env on EACH server, fill in real values, chmod 600.
# nubase_start.sh sources this (set -a) so every var below is exported into the
# java process. NEVER commit the filled-in file — only this placeholder example.
#
# Mirrors the ${ENV_VAR} placeholders in src/main/resources/application.yml.
# Sections marked REQUIRED must be set; others use the app's built-in defaults
# and are only needed if you use that feature.

# ============================================================
# REQUIRED — encryption + platform admin
# ============================================================
# Identical on both servers AND stable over time, or existing tenant
# credentials / platform settings can no longer be decrypted.
export PGRST_ENCRYPTION_MASTER_KEY="REPLACE_ME"
export METADATA_SERVICE_ROLE_KEY="REPLACE_ME"

# ============================================================
# REQUIRED — metadata database (the control-plane DB, shared by both servers)
# ============================================================
export METADATA_DB_URL="jdbc:postgresql://YOUR_PG_HOST:5432/nubase?allowMultiQueries=true"
export METADATA_DB_USER="REPLACE_ME"
export METADATA_DB_PASSWORD="REPLACE_ME"

# ============================================================
# REQUIRED — Postgres host used to PROVISION per-tenant databases.
# Must point at the same Postgres cluster as METADATA_DB_URL above, with a
# superuser-capable account (CREATE DATABASE / CREATE ROLE).
# ============================================================
export POSTGRES_HOST="YOUR_PG_HOST"
export POSTGRES_PORT="5432"

# ============================================================
# Object storage (Cloudflare R2 / S3-compatible) — needed for Storage features.
# ============================================================
export R2_ACCOUNT_ID="your-r2-account-id"
export R2_ACCESS_KEY_ID="REPLACE_ME"
export R2_SECRET_ACCESS_KEY="REPLACE_ME"
export R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
export R2_PUBLIC_URL=""
export R2_GLOBAL_BUCKET="nubase-storage"

# Static asset CDN (Assets module). Set both for CDN mode: a dedicated PUBLIC R2 bucket
# plus its custom-domain origin (Cloudflare CDN). Leave empty for backend-served mode.
export NUBASE_ASSETS_BUCKET=""
export NUBASE_ASSETS_PUBLIC_BASE_URL=""

# ============================================================
# Vector store (S3 Vectors) — needed for Memory embeddings/search.
# ============================================================
export S3VECTORS_REGION="us-east-1"
export S3VECTORS_ACCESS_KEY_ID="REPLACE_ME"
export S3VECTORS_SECRET_ACCESS_KEY="REPLACE_ME"
export S3VECTORS_ENDPOINT=""          # empty = AWS default endpoint
export S3VECTORS_BUCKET_NAME="nubase-vectors"

# ============================================================
# Email / SMTP — needed for auth emails (signup, recovery, OTP).
# ============================================================
export SMTP_HOST="smtp.example.com"
export SMTP_PORT="587"
export SMTP_USERNAME=""
export SMTP_PASSWORD=""
export MAIL_FROM_ADDRESS="noreply@example.com"
export MAIL_FROM_NAME="Nubase Auth"
# Public host used to build the links inside tenant auth emails (confirm/recovery/magic-link/invite):
#   {scheme}://{appCode}.{domain}/auth/v1/verify?...
# Leave as localhost for dev. In production set your real domain so links aren't localhost.
# The per-tenant subdomain form needs wildcard DNS (*.your-domain) routed to the app.
export NUBASE_AUTH_APP_DOMAIN="localhost:9999"
export NUBASE_AUTH_APP_SCHEME="http"

# ============================================================
# Redis — required for multi-node deployments (shared rate-limit/lockout + cache).
# Set NUBASE_CACHE_TYPE=redis to also back the cache with Redis (default: caffeine).
# NOTE: the login rate limiter connects to Redis whenever REDIS_HOST is reachable,
# so a multi-node fleet must point these at a real, reachable Redis.
# Fill REDIS_PASSWORD on the SERVER ONLY — never commit a real password to this example.
# ============================================================
# export NUBASE_CACHE_TYPE="redis"
export REDIS_HOST="localhost"
export REDIS_PORT="6379"
export REDIS_PASSWORD=""          # set if your Redis requires AUTH
export REDIS_DATABASE="0"
# export REDIS_SSL="true"         # set for TLS-only managed Redis endpoints

# ============================================================
# LLM providers — only for LLM-powered Memory extraction/search.
# ============================================================
export OPENAI_API_KEY=""
export OPENAI_BASE_URL="https://api.openai.com"
export ANTHROPIC_API_KEY=""
export ANTHROPIC_BASE_URL="https://api.anthropic.com"
export GENERIC_LLM_API_KEY=""
export GENERIC_LLM_BASE_URL=""

# ============================================================
# Studio third-party sign-in (optional) — Google + GitHub for developer accounts.
# Each provider auto-hides on the Studio login page / website until its values
# are set. Register the OAuth apps yourself, then fill these in.
# ============================================================
# Public origin used to build OAuth callback URLs (leave blank to derive from
# the incoming request). Set it when running behind a proxy/CDN, e.g. https://nubase.ai
# export NUBASE_PLATFORM_OAUTH_SITE_URL="https://your-domain.example"
#
# Google Identity Services client id (powers the GIS button AND One Tap on the homepage).
# Authorized JavaScript origins must include your site origin (e.g. https://your-domain.example).
# export NUBASE_PLATFORM_OAUTH_GOOGLE_CLIENT_ID=""
# Optional: set the secret to also enable the GitHub-style "Continue with Google"
# authorization-code redirect. Authorized redirect URI must be:
#   <site-url>/auth/v1/platform/oauth/google/callback
# export NUBASE_PLATFORM_OAUTH_GOOGLE_CLIENT_SECRET=""
#
# GitHub OAuth app. Authorization callback URL must be:
#   <site-url>/auth/v1/platform/oauth/github/callback
# export NUBASE_PLATFORM_OAUTH_GITHUB_CLIENT_ID=""
# export NUBASE_PLATFORM_OAUTH_GITHUB_CLIENT_SECRET=""

# ============================================================
# Tuning (optional) — sensible defaults already baked in.
# ============================================================
# export PGRST_MAX_TOTAL_CONNECTIONS="500"
# export PGRST_DEFAULT_POOL_SIZE="10"
# export FLYWAY_ENABLED="true"
# export NUBASE_SERVER_PORT="9999"   # listen port (default 9999)
